  8211                           ;	FEXTOSC = ECH, EC above 8MHz; PFM set to high power
  8212                           ;	Power-up default value for COSC bits
  8213                           ;	RSTOSC = HFINT32, HFINTOSC with OSCFRQ= 32 MHz and CDIV = 1:1
  8214                           ;	Clock Out Enable bit
  8215                           ;	CLKOUTEN = OFF, CLKOUT function is disabled; i/o or oscillator function on OSC2
  8216                           ;	Clock Switch Enable bit
  8217                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
  8218                           ;	Fail-Safe Clock Monitor Enable bit
  8219                           ;	FCMEN = ON, FSCM timer enabled
  8220     8007                     	org	32775
  8221     8007  3F8F               	dw	16271
  8222                           
  8223                           ;Config register CONFIG2 @ 0x8008
  8224                           ;	Master Clear Enable bit
  8225                           ;	MCLRE = ON, MCLR pin is Master Clear function
  8226                           ;	Power-up Timer Enable bit
  8227                           ;	PWRTE = OFF, PWRT disabled
  8228                           ;	Low-Power BOR enable bit
  8229                           ;	LPBOREN = OFF, ULPBOR disabled
  8230                           ;	Brown-out reset enable bits
  8231                           ;	BOREN = ON, Brown-out Reset Enabled, SBOREN bit is ignored
  8232                           ;	Brown-out Reset Voltage Selection
  8233                           ;	BORV = LO, Brown-out Reset Voltage (VBOR) set to 1.9V on LF, and 2.45V on F Devices
  8234                           ;	Zero-cross detect disable
  8235                           ;	ZCD = OFF, Zero-cross detect circuit is disabled at POR.
  8236                           ;	Peripheral Pin Select one-way control
  8237                           ;	PPS1WAY = ON, The PPSLOCK bit can be cleared and set only once in software
  8238                           ;	Stack Overflow/Underflow Reset Enable bit
  8239                           ;	STVREN = ON, Stack Overflow or Underflow will cause a reset
  8240                           ;	Background Debugger
  8241                           ;	DEBUG = 0x1, unprogrammed default
  8242     8008                     	org	32776
  8243     8008  3FFF               	dw	16383
  8244                           
  8245                           ;Config register CONFIG3 @ 0x8009
